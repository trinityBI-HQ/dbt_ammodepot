# =============================================================================
# Snowflake connection (dbt)
# =============================================================================
# Account identifier: <orgname>-<account_name> or <account_locator>.<region>
SNOWFLAKE_ACCOUNT=your_org-your_account
SNOWFLAKE_DATABASE=AD_AIRBYTE
SNOWFLAKE_WAREHOUSE=ETL_WH
SNOWFLAKE_ROLE=TRANSFORMER_ROLE
SNOWFLAKE_USER=SVC_DBT
SNOWFLAKE_SCHEMA=dbt_dev

# Key-pair auth (path relative to ammodepot/)
SNOWFLAKE_PRIVATE_KEY_PATH=dbt_rsa_key.p8
SNOWFLAKE_PRIVATE_KEY_PASSPHRASE=your_dbt_key_passphrase
