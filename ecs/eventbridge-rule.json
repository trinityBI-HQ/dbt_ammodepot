{
  "Name": "ammodepot-dbt-build-schedule",
  "Description": "Trigger dbt build every 10 minutes on ECS Fargate",
  "ScheduleExpression": "rate(10 minutes)",
  "State": "ENABLED",
  "Targets": [
    {
      "Id": "ammodepot-dbt-build",
      "Arn": "arn:aws:ecs:us-east-1:746669199691:cluster/ammodepot-dbt",
      "RoleArn": "arn:aws:iam::746669199691:role/eventbridge-ecs-dbt",
      "EcsParameters": {
        "TaskDefinitionArn": "arn:aws:ecs:us-east-1:746669199691:task-definition/ammodepot-dbt-build",
        "TaskCount": 1,
        "LaunchType": "FARGATE",
        "PlatformVersion": "LATEST",
        "CapacityProviderStrategy": [
          {
            "capacityProvider": "FARGATE_SPOT",
            "weight": 1,
            "base": 0
          }
        ],
        "NetworkConfiguration": {
          "awsvpcConfiguration": {
            "Subnets": ["PRIVATE_SUBNET_ID"],
            "SecurityGroups": ["SECURITY_GROUP_ID"],
            "AssignPublicIp": "DISABLED"
          }
        }
      },
      "RetryPolicy": {
        "MaximumRetryAttempts": 0,
        "MaximumEventAgeInSeconds": 300
      }
    }
  ]
}
