{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowRunTask",
      "Effect": "Allow",
      "Action": "ecs:RunTask",
      "Resource": "arn:aws:ecs:us-east-1:746669199691:task-definition/ammodepot-dbt-build:*",
      "Condition": {
        "ArnEquals": {
          "ecs:cluster": "arn:aws:ecs:us-east-1:746669199691:cluster/ammodepot-dbt"
        }
      }
    },
    {
      "Sid": "AllowPassRole",
      "Effect": "Allow",
      "Action": "iam:PassRole",
      "Resource": [
        "arn:aws:iam::746669199691:role/ecsTaskExecutionRole-dbt",
        "arn:aws:iam::746669199691:role/ecsTaskRole-dbt"
      ]
    }
  ]
}
