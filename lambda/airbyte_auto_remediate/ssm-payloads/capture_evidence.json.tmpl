{
  "commands": [
    "NS=airbyte-abctl",
    "echo CAPTURE_CONNECTION_ID=__CONNECTION_ID__",
    "CID=$(sudo docker exec airbyte-abctl-control-plane kubectl get secret -n $NS airbyte-auth-secrets -o jsonpath='{.data.instance-admin-client-id}' 2>/dev/null | base64 -d) || true",
    "CSEC=$(sudo docker exec airbyte-abctl-control-plane kubectl get secret -n $NS airbyte-auth-secrets -o jsonpath='{.data.instance-admin-client-secret}' 2>/dev/null | base64 -d) || true",
    "TOKEN=$(curl -fsS -X POST http://localhost:8000/api/v1/applications/token -H 'Content-Type: application/json' -d \"{\\\"client_id\\\":\\\"$CID\\\",\\\"client_secret\\\":\\\"$CSEC\\\",\\\"grant-type\\\":\\\"client_credentials\\\"}\" 2>/dev/null | jq -r .access_token) || true",
    "if [ -n \"$TOKEN\" ] && [ \"$TOKEN\" != \"null\" ]; then ATTEMPT_JSON=$(curl -fsS -G -H \"Authorization: Bearer $TOKEN\" 'http://localhost:8000/api/public/v1/jobs' --data-urlencode 'connectionId=__CONNECTION_ID__' --data-urlencode 'limit=1' --data-urlencode 'orderBy=createdAt|DESC' 2>/dev/null | jq -c '.data[0] // {}'); else ATTEMPT_JSON='{}'; echo CAPTURE_TOKEN_FAILED; fi",
    "echo ATTEMPT_JSON=${ATTEMPT_JSON:-{}}",
    "EV=$(sudo docker exec airbyte-abctl-control-plane kubectl get events -n $NS --field-selector type=Warning --sort-by=.metadata.creationTimestamp -o json 2>/dev/null | jq -c '[.items[] | {reason:.reason, eventTime:(.eventTime // .firstTimestamp), firstTs:.firstTimestamp, lastTs:.lastTimestamp, count:.count, obj:.involvedObject.name}] | .[0:25]') || EV='[]'",
    "echo K8S_EVENTS_JSON=${EV:-[]}",
    "CUT=$(date -u -d '40 minutes ago' +%Y-%m-%dT%H:%M:%SZ)",
    "PODS=$(sudo docker exec airbyte-abctl-control-plane kubectl get pods -n $NS -o json 2>/dev/null | jq -c --arg cut \"$CUT\" '[.items[] | select(.metadata.creationTimestamp > $cut) | {name:.metadata.name, phase:.status.phase, created:.metadata.creationTimestamp, rc:([.status.containerStatuses[]?.restartCount] | add), term:[.status.containerStatuses[]? | select(.lastState.terminated != null) | {name:.name, reason:.lastState.terminated.reason, exit:.lastState.terminated.exitCode, finishedAt:.lastState.terminated.finishedAt}], conds:[.status.conditions[]? | {t:.type, s:.status, lt:.lastTransitionTime}]}]') || PODS='[]'",
    "echo PODS_JSON=${PODS:-[]}",
    "NODE=$(sudo docker exec airbyte-abctl-control-plane kubectl get nodes -o json 2>/dev/null | jq -c '[.items[0].status.conditions[] | {t:.type, s:.status, lt:.lastTransitionTime}]') || NODE='[]'",
    "echo NODE_CONDITIONS_JSON=${NODE:-[]}",
    "echo CAPTURE_DONE=1"
  ]
}
