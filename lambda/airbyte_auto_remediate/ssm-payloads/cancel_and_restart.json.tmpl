{
  "commands": [
    "set -e",
    "export CID=$(sudo docker exec airbyte-abctl-control-plane kubectl get secret -n airbyte-abctl airbyte-auth-secrets -o jsonpath='{.data.instance-admin-client-id}' | base64 -d)",
    "export CSEC=$(sudo docker exec airbyte-abctl-control-plane kubectl get secret -n airbyte-abctl airbyte-auth-secrets -o jsonpath='{.data.instance-admin-client-secret}' | base64 -d)",
    "export TOKEN=$(curl -fsS -X POST http://localhost:8000/api/v1/applications/token -H 'Content-Type: application/json' -d \"{\\\"client_id\\\":\\\"$CID\\\",\\\"client_secret\\\":\\\"$CSEC\\\",\\\"grant-type\\\":\\\"client_credentials\\\"}\" | jq -r .access_token)",
    "if [ -z \"$TOKEN\" ] || [ \"$TOKEN\" = \"null\" ]; then echo TOKEN_FAILURE >&2; exit 41; fi",
    "echo CONNECTION_ID=__CONNECTION_ID__",
    "JOB_JSON=$(curl -fsS -G -H \"Authorization: Bearer $TOKEN\" 'http://localhost:8000/api/public/v1/jobs' --data-urlencode 'connectionId=__CONNECTION_ID__' --data-urlencode 'limit=1' --data-urlencode 'orderBy=createdAt|DESC')",
    "CANCEL_JOB_ID=$(echo \"$JOB_JSON\" | jq -r '.data[0].jobId // .data[0].id // empty')",
    "CANCEL_STATUS=$(echo \"$JOB_JSON\" | jq -r '.data[0].status // empty')",
    "echo CANCEL_JOB_ID=$CANCEL_JOB_ID",
    "echo CANCEL_STATUS=$CANCEL_STATUS",
    "if [ -n \"$CANCEL_JOB_ID\" ] && [ \"$CANCEL_STATUS\" = \"running\" ]; then curl -fsS -X DELETE -H \"Authorization: Bearer $TOKEN\" \"http://localhost:8000/api/public/v1/jobs/$CANCEL_JOB_ID\" || { echo CANCEL_FAILURE >&2; exit 42; }; echo CANCEL_OK; sleep 5; else echo CANCEL_SKIPPED_NOT_RUNNING; fi",
    "RESTART_JSON=$(curl -fsS -X POST -H \"Authorization: Bearer $TOKEN\" -H 'Content-Type: application/json' 'http://localhost:8000/api/public/v1/jobs' -d \"{\\\"connectionId\\\":\\\"__CONNECTION_ID__\\\",\\\"jobType\\\":\\\"sync\\\"}\")",
    "RESTART_JOB_ID=$(echo \"$RESTART_JSON\" | jq -r '.jobId // .id // empty')",
    "echo RESTART_JOB_ID=$RESTART_JOB_ID",
    "if [ -z \"$RESTART_JOB_ID\" ]; then echo RESTART_FAILURE >&2; exit 43; fi",
    "echo RESTART_OK"
  ]
}
