[sqlfluff]
dialect = redshift
templater = jinja
max_line_length = 120
large_file_skip_byte_limit = 0
# Excluded rules:
# LT01: trailing whitespace (too noisy)
# LT02: indentation of comments (too strict)
# LT05: comma style (personal preference)
# LT09: select targets (too strict)
# ST01: else/then on same line (flexible)
# ST04: nested case when (needed in complex models)
# ST05: CTE naming (flexible)
# ST06: select wildcard (handled via code review)
# ST09: from clause style (flexible)
# AM04: column count (not useful)
# RF02: column qualification (too noisy)
# AL09: self-alias (intentional UPPER_CASE output aliases)
# RF04: keywords as identifiers (NAME, VALUE, STATUS used intentionally)
# CP02: identifier casing (UPPER_CASE output aliases for BI compatibility)
exclude_rules = LT01,LT02,LT05,LT09,ST01,ST04,ST05,ST06,ST09,AM04,RF02,AL09,RF04,CP02

[sqlfluff:templater:jinja]
apply_dbt_builtins = true

[sqlfluff:indentation]
indent_unit = space
tab_space_size = 4

[sqlfluff:rules:capitalisation.keywords]
capitalisation_policy = lower

[sqlfluff:rules:capitalisation.functions]
capitalisation_policy = lower

[sqlfluff:rules:capitalisation.literals]
capitalisation_policy = lower

[sqlfluff:rules:capitalisation.types]
capitalisation_policy = lower
